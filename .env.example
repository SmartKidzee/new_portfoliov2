# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase Service Role Key (for server-side operations only)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter Configuration for AI blog summaries/chat
OPENROUTER_API_KEY=your-openrouter-api-key-here
# Set one model, or use OPENROUTER_MODELS for a comma-separated fallback list.
# Free models can return 503 when the upstream provider is busy.
OPENROUTER_MODEL=meta-llama/llama-3.3-8b-instruct:free
# OPENROUTER_MODELS=meta-llama/llama-3.3-8b-instruct:free,openrouter/auto
OPENROUTER_APP_NAME=Shreyas Portfolio

# Optional: used for OpenRouter referer header
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact Form Configuration
HUNTER_API_KEY=your-hunter-api-key-here
WEB3FORMS_ACCESS_KEY=79598993-2a84-422f-8872-a30089fffbf4
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SMTP / Nodemailer
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
CONTACT_FROM_EMAIL=hello@shreyas.cloud
# Optional: override reply-to for auto-replies
# CONTACT_REPLY_TO_EMAIL=hello@shreyas.cloud
